# =============================================================================
# AWS Secrets Configuration - EXAMPLE FILE
# =============================================================================
# IMPORTANT: Copy this file to secrets.yml and fill in your actual credentials.
# NEVER commit secrets.yml to version control!
#
# Alternatively, use environment variables:
#   export AWS_ACCESS_KEY_ID="your-access-key"
#   export AWS_SECRET_ACCESS_KEY="your-secret-key"
#   export AWS_DEFAULT_REGION="us-east-2"
# =============================================================================

aws:
  region: us-east-2
  access_key_id: YOUR_ACCESS_KEY_ID_HERE
  secret_access_key: YOUR_SECRET_ACCESS_KEY_HERE
  session_token: ""  # Optional: only needed for temporary credentials
